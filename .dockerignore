# keep the build context small, secret-free, state-free
**/.venv
**/__pycache__
**/*.pyc
**/*.egg-info
**/.pytest_cache
**/dist
**/build
.git
.github
# language dirs not needed for the support image
typescript
java
rust
mcp-server
# runtime state / secrets / artifacts — never in the image
support/data
support/logs
support/config.yaml
support/.env
**/*.db
**/*.db-*
**/*.tar.gz
support/bridges/whatsapp-web/node_modules
